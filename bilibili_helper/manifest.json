{
  "manifest_version": 3,
  "name": "Bilibili 助手",
  "version": "1.0.0",
  "description": "Bilibili 稍后观看管理工具",
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bilibili_watch_later_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://www.bilibili.com/*",
    "https://passport.bilibili.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/*"],
      "js": ["content.js"]
    }
  ]
}
